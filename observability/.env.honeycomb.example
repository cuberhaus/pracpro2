# Copy to `.env.honeycomb` (gitignored) and fill in your Honeycomb API key.
# Source it before `cargo run`:
#   set -a; source observability/.env.honeycomb; set +a
#   cd web/backend && cargo run
#
# These are the OTel-standard env vars; the SDK reads them automatically
# when `observability::init_otel` calls `SpanExporter::builder().with_tonic()`.

# Service identity in Honeycomb's UI. Maps to `service.name` resource attribute.
OTEL_SERVICE_NAME=pracpro2

# Honeycomb's gRPC endpoint. The :443 is required; without it tonic defaults
# to plaintext and the handshake silently fails (the only symptom is "0
# spans received" in Honeycomb after 60 s).
#
# Region check: Honeycomb has two ingestion zones. Most free-tier signups
# land on US; only deliberate EU signups land on api.eu1.honeycomb.io.
# A 401 "unknown API key" error usually means the key is for the *other*
# region — try flipping the URL before assuming the key is bad.
#
#   US (default):  https://api.honeycomb.io:443
#   EU:            https://api.eu1.honeycomb.io:443
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io:443

# Honeycomb's auth header. Replace with the ingest key from
# https://ui.honeycomb.io/<your-team>/environments/<env>/api_keys.
# Multiple headers are comma-separated: header1=val1,header2=val2.
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_INGEST_KEY_HERE

# Resource attributes get attached to every span as columns in Honeycomb.
# `deployment.environment` doubles as Honeycomb's "environment" filter so
# local-dev traces don't pollute the production dataset later.
OTEL_RESOURCE_ATTRIBUTES=service.namespace=cuberhaus,deployment.environment=local-dev,service.version=0.1.0

# tracing-subscriber filter. `info` keeps it quiet; `pracpro2_backend=debug`
# turns on the per-handler instrumentation we added in Phase C.
RUST_LOG=info,pracpro2_backend=debug

# Optional: set to `1` to also dump every span to stdout for debugging.
# Off by default — Honeycomb is the source of truth.
# OTEL_TRACES_EXPORTER=otlp,console
